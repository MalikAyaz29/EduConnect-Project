@page "/admin/students/add"
@inject IStudentService StudentService
@inject NavigationManager Navigation

<h3>Add New Student</h3>

<div class="card mt-4 shadow-sm border-0">
    <div class="card-body p-4">
        <AlertBox Message="@ErrorMessage" Type="AlertType.Error" />

        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">First Name</label>
                <input type="text" class="form-control" @bind="Student.FirstName" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Last Name</label>
                <input type="text" class="form-control" @bind="Student.LastName" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Email Address</label>
                <input type="email" class="form-control" @bind="Student.Email" />
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Temporary Password</label>
                <input type="password" class="form-control" @bind="Student.Password" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-4 mb-4">
                <label class="form-label fw-bold">Declared Major</label>
                <input type="text" class="form-control" @bind="Student.Major" />
            </div>
            <div class="col-md-4 mb-4">
                <label class="form-label fw-bold">Semester</label>
                <select class="form-select" @bind="Student.Semester">
                    @for (int i = 1; i <= 8; i++)
                    {
                        <option value="@i">Semester @i</option>
                    }
                </select>
            </div>
            <div class="col-md-4 mb-4">
                <label class="form-label fw-bold">CGPA (Initial)</label>
                <input type="number" step="0.01" class="form-control" @bind="Student.CGPA" />
            </div>
        </div>

        <button class="btn btn-success px-4 py-2" @onclick="SaveStudent">Save Student</button>
        <button class="btn btn-light ms-2 px-4 py-2" @onclick='() => Navigation.NavigateTo("/admin/students")'>Cancel</button>
    </div>
</div>

@code {
    [CascadingParameter] public IAuthService AuthState { get; set; }
    private Student Student { get; set; } = new Student();
    private string ErrorMessage;

    protected override void OnInitialized()
    {
        if (!AuthState.IsLoggedIn || AuthState.CurrentUser.Role != Role.Admin)
        {
            Navigation.NavigateTo("/unauthorized");
        }
    }

    private void SaveStudent()
    {
        // Utilizing the IValidatable interface
        if (!Student.IsValid())
        {
            ErrorMessage = string.Join(" | ", Student.GetValidationErrors());
            return;
        }

        StudentService.AddStudent(Student);
        Navigation.NavigateTo("/admin/students");
    }
}
