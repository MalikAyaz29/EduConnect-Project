@page "/login"
@page "/"
@inject NavigationManager Navigation

<div class="login-wrapper">
    <div class="row justify-content-center align-items-center min-vh-100 m-0">
        <div class="col-md-4">
        <div class="card shadow-lg border-0">
            <div class="card-header bg-primary text-white text-center py-3">
                <img src="/images/logo.jpeg" alt="EduConnect Logo" style="height: 60px; margin-bottom: 10px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);" />
                <h4 class="mb-0">EduConnect Login</h4>
            </div>
            <div class="card-body p-4">
                <AlertBox Message="@ErrorMessage" Type="AlertType.Error" OnClose="() => ErrorMessage = null" />
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Email address</label>
                    <input type="email" class="form-control" @bind="Email" placeholder="admin@educonnect.com" />
                </div>
                <div class="mb-4">
                    <label class="form-label fw-bold">Password</label>
                    <input type="password" class="form-control" @bind="Password" placeholder="password" />
                </div>
                <button class="btn btn-primary w-100 py-2 fw-bold" @onclick="HandleLogin">Secure Login</button>
                
                <div class="mt-3 small text-muted text-center">
                    (Default admin: admin@educonnect.com / password)
                </div>
            </div>
        </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] public IAuthService AuthState { get; set; }
    private string Email { get; set; } = "";
    private string Password { get; set; } = "";
    private string ErrorMessage { get; set; }

    protected override void OnInitialized()
    {
        if (AuthState.IsLoggedIn)
        {
            Navigation.NavigateTo("/dashboard");
        }
    }

    private void HandleLogin()
    {
        if (AuthState.Login(Email, Password))
        {
            Navigation.NavigateTo("/dashboard");
        }
        else
        {
            ErrorMessage = "Invalid email or password.";
        }
    }
}
