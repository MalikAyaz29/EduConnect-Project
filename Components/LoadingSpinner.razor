@if (IsVisible)
{
    <div class="d-flex justify-content-center my-4 align-items-center flex-column">
        <div class="spinner-border text-primary mb-2" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <div class="text-muted fw-bold">@Message</div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; } = false;
    [Parameter] public string Message { get; set; } = "Loading data...";
}
